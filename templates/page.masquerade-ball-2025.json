{"sections":{"image_banner_RQb9nx":{"type":"image-banner","blocks":{"heading_E8C8BT":{"type":"heading","disabled":true,"settings":{"heading":"Image banner","heading_size":"h1"}},"text_8E3mz7":{"type":"text","disabled":true,"settings":{"text":"Give customers details about the banner image(s) or content on the template.","text_style":"body"}},"buttons_YUr8fw":{"type":"buttons","disabled":true,"settings":{"button_label_1":"Button label","button_link_1":"","button_style_secondary_1":false,"button_label_2":"Button label","button_link_2":"","button_style_secondary_2":false}}},"block_order":["heading_E8C8BT","text_8E3mz7","buttons_YUr8fw"],"name":"t:sections.image-banner.presets.name","settings":{"image":"shopify:\/\/shop_images\/NYE_Promo.jpg","image_overlay_opacity":0,"image_height":"adapt","desktop_content_position":"middle-center","show_text_box":true,"desktop_content_alignment":"center","color_scheme":"","image_behavior":"none","mobile_content_alignment":"center","stack_images_on_mobile":true,"show_text_below":false}},"main":{"type":"main-page","disabled":true,"settings":{"padding_top":24,"padding_bottom":24}},"rich_text_cKczxB":{"type":"rich-text","blocks":{"heading_gwYAg3":{"type":"heading","settings":{"heading":"<strong>Celebrate New Year’s Eve 2026 at The Londoner Hotel                       <\/strong>","heading_size":"h2"}},"text_pmHbBM":{"type":"text","settings":{"text":"<p>Join us for an unforgettable night of elegance, entertainment, and celebration as Luxury London Events returns with the second edition of its prestigious <a href=\"\/\" title=\"\/\"><strong>New Year's Eve London 2026<\/strong><\/a><strong> Masquerade Ball and After Party<\/strong> at the iconic <strong>Londoner Hotel in Leicester Square.<\/strong><\/p><p><strong>The Sequel to a Legendary Evening<\/strong><\/p><p><strong>Following a sold-out event in 2025<\/strong>, this year's celebration on <strong>31st December 2026<\/strong> promises to be even more spectacular. Previously hosted at The Dorchester, Park Lane Hilton, and The Sheraton, the event now takes place across two stunning floors of the five-star Londoner, accommodating up to <strong>700 guests<\/strong> in style.<\/p><h2>Last Few Party Only Tickets Remaining<\/h2><p><strong>Arrive from 21:30<\/strong> and step straight into the <strong>New Year’s Eve Masquerade Party at The Londoner<br\/>Hotel<\/strong>, London’s most exclusive celebration in the heart of the West End.<\/p><p>Experience the electric atmosphere across two floors — the <strong>Ballroom<\/strong> (after-dinner) and <strong>The Gallery (Chillout Room)<\/strong> — featuring a <strong>Live Band<\/strong>,<strong> DJs, and midnight celebrations<\/strong> streamed from Big Ben.<\/p><p>Enjoy a night of luxury with <strong>entertainment, dancing, and midnight snacks.<\/strong><\/p><p><strong>Party until 02:30am<\/strong> at London’s premier New Year’s Eve after-dinner celebration.<\/p><p><strong>Last Entry: 23:55<\/strong><\/p><p><strong>LAST FEW TICKETS REMAINING!<\/strong><br\/><\/p>"}},"button_N7fRcU":{"type":"button","settings":{"button_label":"Buy Tickets","button_link":"shopify:\/\/collections\/new-years-eve-at-the-londoner-2026","button_style_secondary":false,"button_label_2":"","button_link_2":"","button_style_secondary_2":false}}},"block_order":["heading_gwYAg3","text_pmHbBM","button_N7fRcU"],"settings":{"desktop_content_position":"center","content_alignment":"center","color_scheme":"","full_width":true,"padding_top":36,"padding_bottom":36}},"multicolumn_zGtwfA":{"type":"multicolumn","blocks":{"column_EN47Xn":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/london-nye-masquerade-gold-confetti.webp","title":"","text":"","link_label":"","link":""}},"column_FDbXtz":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/london-nye-masquerade-live-band-bw.webp","title":"","text":"","link_label":"","link":""}},"column_UfULwT":{"type":"column","settings":{"image":"shopify:\/\/shop_images\/london-nye-masquerade-empty-stage.webp","title":"","text":"","link_label":"","link":""}}},"block_order":["column_EN47Xn","column_FDbXtz","column_UfULwT"],"settings":{"title":"","heading_size":"h2","image_width":"full","image_ratio":"adapt","columns_desktop":3,"column_alignment":"center","background_style":"none","button_label":"","button_link":"","color_scheme":"","columns_mobile":"1","swipe_on_mobile":true,"padding_top":0,"padding_bottom":0}},"rich_text_FpLWeT":{"type":"rich-text","blocks":{"text_FjfrBW":{"type":"text","settings":{"text":"<p><strong>Ticket Options:<\/strong><\/p><p><a href=\"\/collections\/new-years-eve-at-the-londoner-2026\" title=\"New Year's Eve London 2026 | NYE Masquerade Ball at The Londoner Hotel\"><strong>Party Only Tickets starting from £180 - Last Few Tickets Remaining<\/strong><\/a><\/p><p><a href=\"\/collections\/new-years-eve-at-the-londoner-2026\" title=\"New Year's Eve London 2026 | NYE Masquerade Ball at The Londoner Hotel\"><strong>Silver Tickets starting from £425 - Sold Out<\/strong><\/a><\/p><p><a href=\"\/collections\/new-years-eve-at-the-londoner-2026\" title=\"New Year's Eve London 2026 | NYE Masquerade Ball at The Londoner Hotel\"><strong>Gold Tickets starting from £545 - Sold Out<\/strong><\/a><\/p><p><a href=\"\/collections\/new-years-eve-at-the-londoner-2026\" title=\"New Year's Eve London 2026 | NYE Masquerade Ball at The Londoner Hotel\"><strong>Platinum Tickets starting from £595 - Sold Out<\/strong><\/a><\/p>"}}},"block_order":["text_FjfrBW"],"settings":{"desktop_content_position":"center","content_alignment":"center","color_scheme":"","full_width":true,"padding_top":24,"padding_bottom":0}},"rich_text_xzGmYt":{"type":"rich-text","blocks":{"text_cdPzeH":{"type":"text","settings":{"text":"<p><strong>Event Highlights<\/strong><\/p><ul><li><strong>Doors Open:<\/strong> 19:00, <strong>Dinner<\/strong>: 20:15, <strong>Party Only Entry<\/strong>: 21:30, <strong>Last Entry:<\/strong> 23:55<strong>, Party Ends:<\/strong> 02:30<\/li><li><strong>Locati