{{ 'section-collection-product-cards.css' | asset_url | stylesheet_tag }}

<div class="collection-product-cards">
  <div
    class="page-width section-collection-product-cards-padding isolate{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
    data-cascade
    {% endif %}>
    {%- unless section.settings.title == blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin">
        <h2 class="visually-hidden">
          {{ section.settings.title }}
        </h2>
      </div>
    {%- endunless -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="collection-product-cards__list" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign book_url = blank
            if block.settings.button_product != blank
              assign book_url = block.settings.button_product.url
            endif
            if book_url == blank and block.settings.ticket_product_1 != blank
              assign book_url = block.settings.ticket_product_1.url
            endif
            if book_url == blank and block.settings.ticket_product_2 != blank
              assign book_url = block.settings.ticket_product_2.url
            endif
            if book_url == blank and block.settings.ticket_product_3 != blank
              assign book_url = block.settings.ticket_product_3.url
            endif
            if book_url == blank and block.settings.ticket_product_4 != blank
              assign book_url = block.settings.ticket_product_4.url
            endif

            assign has_ticket_options = false
            if block.settings.ticket_label_1 != blank or block.settings.ticket_product_1 != blank
              assign has_ticket_options = true
            endif
            if block.settings.ticket_label_2 != blank or block.settings.ticket_product_2 != blank
              assign has_ticket_options = true
            endif
            if block.settings.ticket_label_3 != blank or block.settings.ticket_product_3 != blank
              assign has_ticket_options = true
            endif
            if block.settings.ticket_label_4 != blank or block.settings.ticket_product_4 != blank
              assign has_ticket_options = true
            endif
          -%}

          <li
            class="collection-product-cards__item {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
            data-cascade
            style="--animation-order: {{ forloop.index }};"
            {% endif %}>
            <article class="collection-product-cards__card content-container">
              <div class="collection-product-cards__media{% if block.settings.image == blank %} collection-product-cards__placeholder{% endif %}">
                {%- if block.settings.badge != blank -%}
                  <span class="collection-product-cards__badge">{{ block.settings.badge | escape }}</span>
                {%- endif -%}
                {%- if block.settings.image != blank -%}
                  {%- liquid
                    assign columns_desktop = 4
                    assign grid_space_desktop = columns_desktop | minus: 1 | times: settings.spacing_grid_horizontal | plus: 100 | append: 'px'
                    assign grid_space_mobile = settings.spacing_grid_horizontal | divided_by: 2 | plus: 30 | append: 'px'
                  -%}
                  {% capture sizes %}
                    (min-width: {{ settings.page_width }}px) calc(({{ settings.page_width }}px - {{ grid_space_desktop }}) / {{ columns_desktop }}),
                    (min-width: 750px) calc((100vw - {{ grid_space_desktop }}) / {{ columns_desktop }}),
                    calc(100vw - {{ grid_space_mobile }})
                  {% endcapture %}
                  {%- liquid
                    assign image_alt = block.settings.image.alt | default: block.settings.title | strip_html
                  -%}
                  {{
                    block.settings.image | image_url: width: 1500 | image_tag: widths: '165, 360, 535, 750, 1000, 1500', sizes: sizes, loading: 'lazy', alt: image_alt
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>

              <div class="collection-product-cards__body">
                {%- if block.settings.title != blank -%}
                  <h3 class="collection-product-cards__title inline-richtext">
                    {{ block.settings.title }}
                  </h3>
                {%- endif -%}

                {%- if block.settings.price != blank -%}
                  <p class="collection-product-cards__price">{{ block.settings.price | escape }}</p>
                {%- endif -%}

                {%- if block.settings.subtitle != blank -%}
                  <p class="collection-product-cards__subtitle">{{ block.settings.subtitle | escape }}</p>
                {%- endif -%}

                {%- if block.settings.button_label != blank -%}
                  <div class="collection-product-cards__cta">
                    <a
                      class="collection-product-cards__button"
                      {% if book_url == blank %}
                      role="link"
                      aria-disabled="true"
                      {% else %}
                      href="{{ book_url }}"
                      {% endif %}>
                      {{ block.settings.button_label | escape }}
                    </a>
                  </div>
                {%- endif -%}

                {%- if block.settings.features != blank -%}
                  {%- if block.settings.features_heading != blank -%}
                    <details class="collection-product-cards__features rte">
                      <summary class="collection-product-cards__features-heading">
                        <span>{{ block.settings.features_heading | escape }}</span>
                        {% render 'icon-caret' %}
                      </summary>
                      <div class="collection-product-cards__features-content">
                        {{ block.settings.features }}
                      </div>
                    </details>
                  {%- else -%}
                    <div class="collection-product-cards__features rte">
                      {{ block.settings.features }}
                    </div>
                  {%- endif -%}
                {%- endif -%}

                {%- if has_ticket_options -%}
                  <div class="collection-product-cards__ticket-options">
                    {%- if block.settings.ticket_options_heading != blank -%}
                      <p class="collection-product-cards__ticket-heading">
                        {{ block.settings.ticket_options_heading | escape }}
                      </p>
                    {%- endif -%}
                    <ul class="collection-product-cards__ticket-list">
                      {%- if block.settings.ticket_label_1 != blank or block.settings.ticket_product_1 != blank -%}
                        <li>
                          {%- if block.settings.ticket_product_1 != blank -%}
                            <a href="{{ block.settings.ticket_product_1.url }}">
                              {%- if block.settings.ticket_label_1 != blank -%}
                                {{ block.settings.ticket_label_1 | escape }}
                              {%- else -%}
                                {{ block.settings.ticket_product_1.title | escape }}
                              {%- endif -%}
                            </a>
                          {%- else -%}
                            {{ block.settings.ticket_label_1 | escape }}
                          {%- endif -%}
                        </li>
                      {%- endif -%}
                      {%- if block.settings.ticket_label_2 != blank or block.settings.ticket_product_2 != blank -%}
                        <li>
                          {%- if block.settings.ticket_product_2 != blank -%}
                            <a href="{{ block.settings.ticket_product_2.url }}">
                              {%- if block.settings.ticket_label_2 != blank -%}
                                {{ block.settings.ticket_label_2 | escape }}
                              {%- else -%}
                                {{ block.settings.ticket_product_2.title | escape }}
                              {%- endif -%}
                            </a>
                          {%- else -%}
                            {{ block.settings.ticket_label_2 | escape }}
                          {%- endif -%}
                        </li>
                      {%- endif -%}
                      {%- if block.settings.ticket_label_3 != blank or block.settings.ticket_product_3 != blank -%}
                        <li>
                          {%- if block.settings.ticket_product_3 != blank -%}
                            <a href="{{ block.settings.ticket_product_3.url }}">
                              {%- if block.settings.ticket_label_3 != blank -%}
                                {{ block.settings.ticket_label_3 | escape }}
                              {%- else -%}
                                {{ block.settings.ticket_product_3.title | escape }}
                              {%- endif -%}
                            </a>
                          {%- else -%}
                            {{ block.settings.ticket_label_3 | escape }}
                          {%- endif -%}
                        </li>
                      {%- endif -%}
                      {%- if block.settings.ticket_label_4 != blank or block.settings.ticket_product_4 != blank -%}
                        <li>
                          {%- if block.settings.ticket_product_4 != blank -%}
                            <a href="{{ block.settings.ticket_product_4.url }}">
                              {%- if block.settings.ticket_label_4 != blank -%}
                                {{ block.settings.ticket_label_4 | escape }}
                              {%- else -%}
                                {{ block.settings.ticket_product_4.title | escape }}
                              {%- endif -%}
                            </a>
                          {%- else -%}
                            {{ block.settings.ticket_label_4 | escape }}
                          {%- endif -%}
                        </li>
                      {%- endif -%}
                    </ul>
                  </div>
                {%- endif -%}

              </div>
            </article>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

<script>
  (() => {
    const section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    const mediaQuery = window.matchMedia('(min-width: 750px)');
    const syncFeaturesAccordions = () => {
      section.querySelectorAll('details.collection-product-cards__features').forEach((details) => {
        details.open = mediaQuery.matches;
      });
    };

    syncFeaturesAccordions();
    mediaQuery.addEventListener('change', syncFeaturesAccordions);
  })();
</script>

